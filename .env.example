# Copy to .env. Never commit the real file.
DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=60
JWT_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_MINUTES=120
INITIAL_ADMIN_EMAIL=admin@campusqa.cn
INITIAL_ADMIN_NAME=系统管理员
# Used by `create-admin` and real smoke tests; keep blank in Git and local-only.
INITIAL_ADMIN_PASSWORD=

# Local demo: keep credentials only in .env. MYSQL_PASSWORD may contain @ or
# other reserved URL characters because the application builds the URL safely.
DB_BACKEND=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-your-local-password
MYSQL_DATABASE=campus_qa
# DATABASE_URL can override the fields above (CI/tests may use SQLite).
DATABASE_URL=
DATA_DIR=./data
KNOWLEDGE_DIR=./knowledge_docs
FRONTEND_DIST=./frontend/dist

EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512
EMBEDDING_BATCH_SIZE=32
MODEL_DEVICE=auto
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_MAX_LENGTH=256
RERANK_CANDIDATE_K=5
# Set true only after both models have been cached for an offline demo.
MODEL_LOCAL_FILES_ONLY=false
RAG_PREWARM=true
RERANK_ENABLED=true
# Calibrated for rerank=true. For hybrid without rerank use 0.6526.
RETRIEVAL_MIN_SCORE=0.7256
RETRIEVAL_LEXICAL_OVERRIDE_SCORE=0.70
RETRIEVAL_LEXICAL_MIN_COVERAGE=0.8
RETRIEVAL_HYBRID_MAX_RANK=3
RETRIEVAL_CONTEXT_MIN_SCORE=0.60
RETRIEVAL_CONTEXT_SCORE_MARGIN=0.20
DENSE_TOP_K=20
SPARSE_TOP_K=20
FUSION_TOP_K=12
CONTEXT_TOP_K=5
RRF_K=60

WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=free
WEB_SEARCH_SNIPPET_MAX_CHARS=360
WEB_SEARCH_CONTENT_MAX_CHARS=1200
FREE_SEARCH_REGION=cn-zh
FREE_SEARCH_SAFE_SEARCH=moderate
FREE_SEARCH_TIME_LIMIT=
FREE_SEARCH_BACKEND=auto
FREE_SEARCH_MAX_RESULTS=5
FREE_SEARCH_TIMEOUT_SECONDS=15
# Optional paid fallback provider.
BAIDU_SEARCH_BASE_URL=https://qianfan.baidubce.com
BAIDU_SEARCH_PATH=/v2/ai_search/web_search
BAIDU_SEARCH_API_KEY=
BAIDU_SEARCH_AUTH_HEADER=X-Appbuilder-Authorization
BAIDU_SEARCH_MAX_RESULTS=5
BAIDU_SEARCH_TIMEOUT_CONNECT_SECONDS=5
BAIDU_SEARCH_TIMEOUT_READ_SECONDS=15
BAIDU_SEARCH_SAFE_SEARCH=true
# Optional filters from Baidu AI Search.
BAIDU_SEARCH_RECENCY_FILTER=
BAIDU_SEARCH_MATCH_SITE=
BAIDU_SEARCH_BLOCK_WEBSITES=

ANSWER_KNOWLEDGE_CATEGORY=问答沉淀
ANSWER_WEB_ARCHIVE_CATEGORY=网页归档
ANSWER_CORRECTION_CATEGORY=用户纠错（已审核）
ANSWER_KNOWLEDGE_MAX_ANSWER_CHARS=6000
ANSWER_KNOWLEDGE_MAX_SOURCE_CHARS=6000
QA_RETRIEVAL_ENABLED=true
QA_RETRIEVAL_TOP_K=3
QA_DIRECT_MIN_SCORE=0.96
QA_ASSIST_MIN_SCORE=0.86
QA_DEDUPE_MIN_SCORE=0.97
QA_MIN_SCORE_MARGIN=0.03
QA_TIME_SENSITIVE_MAX_AGE_DAYS=120
EVIDENCE_SUFFICIENCY_CHECK_ENABLED=true

CHUNK_SIZE=500
CHUNK_OVERLAP=80
MAX_UPLOAD_BYTES=52428800
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
